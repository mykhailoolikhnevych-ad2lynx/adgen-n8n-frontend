# ---------------------------------------------------------------------------
# DEV environment template — for the `dev` branch / preview Vercel deployment.
# Mirrors .env.example but every webhook path is prefixed with `dev-`, hitting
# the DEV n8n workflows so test runs don't touch the production data tables /
# Telegram channels / execution IDs that the live site consumes.
#
# The n8n host + the executions REST API (PUBLIC_N8N_EXECUTIONS_URL) and API
# key stay the same as production — only the per-workflow `path` differs.
# ---------------------------------------------------------------------------

# Creatives tab — AdHub Hooks (Image Generator) DEV workflow
PUBLIC_WEBHOOK_ANGLES_URL=https://your-n8n-server.com/webhook/dev-generate_angles
PUBLIC_WEBHOOK_CONCEPT_URL=https://your-n8n-server.com/webhook/dev-generate_concepts
PUBLIC_WEBHOOK_CREATIVE_URL=https://your-n8n-server.com/webhook/dev-generate_creatives
PUBLIC_WEBHOOK_TELEGRAM_URL=https://your-n8n-server.com/webhook/dev-send_to_tg
PUBLIC_WEBHOOK_TRANSLATE_URL=https://your-n8n-server.com/webhook/dev-translate_uk

# Article tab — DEV RSOC article generation workflow
PUBLIC_WEBHOOK_ARTICLE_URL=https://your-n8n-server.com/webhook/dev-rsoc-article

# Keywords tab — DEV Keyword Studio workflow
PUBLIC_WEBHOOK_KEYWORDS_URL=https://your-n8n-server.com/webhook/dev-keyword-studio

# Angles tab — DEV RSOC Audiences & Top-Pick Headlines workflow
PUBLIC_WEBHOOK_RSOC_AUDIENCES_URL=https://your-n8n-server.com/webhook/dev-rsoc-generate-audiences
PUBLIC_WEBHOOK_RSOC_HEADLINES_URL=https://your-n8n-server.com/webhook/dev-rsoc-generate-headlines

# n8n public REST API — used to poll long-running executions (Creatives,
# Keywords, RSOC Audiences/Headlines). Same instance as production.
PUBLIC_N8N_EXECUTIONS_URL=https://your-n8n-server.com/api/v1/executions
PUBLIC_N8N_EXECUTIONS_API=your-n8n-api-key

# Test-data defaults used by the "Test data" button in Creatives Column1.
PUBLIC_TEST_ARTICLE_URL=https://example.com/article
PUBLIC_TEST_KEYWORD1=example keyword
PUBLIC_TEST_GEO=United States (US)
PUBLIC_TEST_BUYER=APP_TEST
PUBLIC_TEST_CAMPAIGN_NAME=CN_MVP_TEST
PUBLIC_TEST_AD_LANGUAGE=English (US)
