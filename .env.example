# Creatives tab — AdHub Hooks (Image Generator) workflow.
PUBLIC_WEBHOOK_ANGLES_URL=https://your-n8n-server.com/webhook/step1
PUBLIC_WEBHOOK_CONCEPT_URL=https://your-n8n-server.com/webhook/step2
PUBLIC_WEBHOOK_CREATIVE_URL=https://your-n8n-server.com/webhook/step3
# Creative Gen tab — dedicated creative-only n8n workflow (new webhook, TBD)
PUBLIC_WEBHOOK_CREATIVE_ONLY_URL=
PUBLIC_WEBHOOK_TELEGRAM_URL=https://your-n8n-server.com/webhook/step4-telegram
PUBLIC_WEBHOOK_TRANSLATE_URL=https://your-n8n-server.com/webhook/translate_uk

# Article tab — RSOC article generation workflow.
PUBLIC_WEBHOOK_ARTICLE_URL=https://your-n8n-server.com/webhook/rsoc-article

# Keywords tab — Keyword Studio workflow.
PUBLIC_WEBHOOK_KEYWORDS_URL=https://your-n8n-server.com/webhook/keyword-studio

# Angles tab — RSOC Audiences & Top-Pick Headlines (two-step HITL flow).
PUBLIC_WEBHOOK_RSOC_AUDIENCES_URL=https://your-n8n-server.com/webhook/rsoc-generate-audiences
PUBLIC_WEBHOOK_RSOC_HEADLINES_URL=https://your-n8n-server.com/webhook/rsoc-generate-headlines

# Dashboard tab — usage analytics (admin-only).
#   log-event   = fire-and-forget POST appending one row to the usage_log table.
#   list-events = admin Dashboard reads recent rows for display.
PUBLIC_WEBHOOK_LOG_EVENT_URL=https://your-n8n-server.com/webhook/log-event
PUBLIC_WEBHOOK_LIST_EVENTS_URL=https://your-n8n-server.com/webhook/list-events
# get-event = on-demand fetch of one row's full meta_out (incl. base64 images).
# list-events strips those bytes from its response to stay light; the Dashboard
# calls this only when the operator clicks "See N images".
PUBLIC_WEBHOOK_GET_EVENT_URL=https://your-n8n-server.com/webhook/get-event

# Docs tab → Prompt Bases (admin-only). Shared prompt library backed by the
# DEV Prompt Bases n8n workflow + prompt_bases Data Table.
#   list-prompts  = GET all rows for the sidebar.
#   save-prompt   = upsert one row by id (id auto-generated if absent).
#   delete-prompt = remove one row by id.


PUBLIC_WEBHOOK_LIST_PROMPTS_URL=https://your-n8n-server.com/webhook/list-prompts
PUBLIC_WEBHOOK_SAVE_PROMPT_URL=https://your-n8n-server.com/webhook/save-prompt
PUBLIC_WEBHOOK_DELETE_PROMPT_URL=https://your-n8n-server.com/webhook/delete-prompt

PUBLIC_WEBHOOK_GET_EVENT_URL=https://your-n8n-server.com/webhook/get-event


PUBLIC_WEBHOOK_CREATIVE_ONLY_URL=https://<your-n8n>/webhook/generate_creatives_only



# n8n public REST API — used to poll long-running executions (Creatives, Keywords,
# RSOC Audiences/Headlines).
PUBLIC_N8N_EXECUTIONS_URL=https://your-n8n-server.com/api/v1/executions
PUBLIC_N8N_EXECUTIONS_API=your-n8n-api-key

# Admin gate for the Dashboard tab — comma-separated Google emails. Set the real
# values in your local .env (gitignored) and in Vercel's env vars; never commit
# real emails to the repo.
PUBLIC_ADMIN_EMAILS=you@example.com,teammate@example.com

# Local dev fallback for Cloudflare Access identity. When running `npm run dev`
# locally /cdn-cgi/access/get-identity 404s (no Cloudflare in front), so we read
# this value instead. Leave unset in production — Cloudflare provides identity.
PUBLIC_DEV_AUTH_EMAIL=you@example.com

# Test-data defaults used by the "Test data" button in Creatives Column1.
PUBLIC_TEST_ARTICLE_URL=https://example.com/article
PUBLIC_TEST_KEYWORD1=example keyword
PUBLIC_TEST_GEO=United States (US)
PUBLIC_TEST_BUYER=APP_TEST
PUBLIC_TEST_CAMPAIGN_NAME=CN_MVP_TEST
PUBLIC_TEST_AD_LANGUAGE=English (US)

# ---------------------------------------------------------------------------
# Note: this file is the single env template. For the dev branch / dev Vercel
# project, use the same variable names with `dev-` prefixed webhook paths
# (e.g. .../webhook/dev-rsoc-article). Real values live in local .env or
# Vercel's UI per project.
# ---------------------------------------------------------------------------
